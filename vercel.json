{
  "rewrites": [
    {
      "source": "/api.php",
      "destination": "https://www.prismglobalservicesltd.com/api.php"
    },
    {
      "source": "/api.php/:query*",
      "destination": "https://www.prismglobalservicesltd.com/api.php/:query*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
